---
/**
 * PostListItem Component
 * A reusable list item for displaying posts (blog posts, newsletters, etc.)
 *
 * @param post - The post to display (Post or Newsletter type)
 */

import { Icon } from 'astro-icon/components';
import Image from '~/components/common/Image.astro';
import PostTags from '~/components/blog/Tags.astro';

import { APP_BLOG, APP_NEWSLETTER } from 'astrowind:config';
import type { Post, Newsletter } from '~/types';

import { getPermalink } from '~/utils/permalinks';
import { findImage } from '~/utils/images';
import { getFormattedDate } from '~/utils/utils';

export interface Props {
  post: Post | Newsletter;
  sharedTagSlugs?: Set<string>;
  isNew?: boolean;
}

const { post, sharedTagSlugs, isNew = false } = Astro.props;
const image = await findImage(post.image);

// Check if image is a remote/public path (string starting with http, /assets/, /blog_images/, or /photos/)
const isRemoteImage =
  typeof image === 'string' &&
  (image.startsWith('http') ||
    image.startsWith('/assets/') ||
    image.startsWith('/blog_images/') ||
    image.startsWith('/photos/'));

// Determine if this is a blog post or newsletter
const isBlogPost = 'tags' in post;
const isNewsletter = 'issue' in post;
const config = isBlogPost ? APP_BLOG : APP_NEWSLETTER;
const link = 'url' in post && post.url ? post.url : config?.post?.isEnabled ? getPermalink(post.permalink, 'post') : '';

// Use imageAlt if provided, otherwise fall back to title for accessibility
const altText = post.imageAlt || post.title;

// Determine object position based on imagePosition field
const getObjectPosition = (position?: 'top' | 'center' | 'bottom') => {
  switch (position) {
    case 'top':
      return 'top';
    case 'bottom':
      return 'bottom';
    case 'center':
    default:
      return 'center';
  }
};

const objectPosition = getObjectPosition(post.imagePosition);
---

<article
  class={`max-w-md mx-auto md:max-w-none grid gap-4 md:gap-6 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade ${image ? 'md:grid-cols-2' : ''} ${isNewsletter ? 'border-4 border-double border-gray-800 dark:border-gray-300 p-6 bg-white dark:bg-slate-800 shadow-xl' : ''}`}
>
  {
    image &&
      (link ? (
        <a class="relative flex items-center justify-center group" href={link ?? 'javascript:void(0)'}>
          {isNew && (
            <span class="absolute -top-2 -left-2 z-10">
              <span class="absolute inset-0 rounded-full dark:animate-ping bg-green-500 dark:bg-green-500 opacity-75" style="animation-duration: 2s;"></span>
              <span class="relative bg-green-500 dark:bg-green-600 text-white text-xs font-bold uppercase tracking-wide px-2.5 py-1 rounded-full shadow-[0_0_10px_2px_rgba(34,197,94,0.6)] dark:shadow-none inline-block">
                New
              </span>
            </span>
          )}
          <div class="relative h-0 pb-[56.25%] md:pb-0 md:h-48 lg:h-52 overflow-hidden bg-white rounded shadow-lg w-full">
            {isRemoteImage ? (
              <img
                src={image}
                class="absolute inset-0 object-cover w-full h-full mb-6 rounded shadow-lg bg-white"
                style={`object-position: ${objectPosition};`}
                alt={altText}
                width="900"
                height="506"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <Image
                src={image}
                class="absolute inset-0 object-cover w-full h-full mb-6 rounded shadow-lg bg-white"
                style={`object-position: ${objectPosition};`}
                widths={[400, 900]}
                width={900}
                sizes="(max-width: 900px) 400px, 900px"
                alt={altText}
                aspectRatio="16:9"
                loading="lazy"
                decoding="async"
              />
            )}
          </div>
        </a>
      ) : (
        <div class="flex items-center justify-center">
          <div class="relative h-0 pb-[56.25%] md:pb-0 md:h-48 lg:h-52 overflow-hidden bg-white rounded shadow-lg w-full">
            {isRemoteImage ? (
              <img
                src={image}
                class="absolute inset-0 object-cover w-full h-full mb-6 rounded shadow-lg bg-white"
                style={`object-position: ${objectPosition};`}
                alt={altText}
                width="900"
                height="506"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <Image
                src={image}
                class="absolute inset-0 object-cover w-full h-full mb-6 rounded shadow-lg bg-white"
                style={`object-position: ${objectPosition};`}
                widths={[400, 900]}
                width={900}
                sizes="(max-width: 900px) 400px, 900px"
                alt={altText}
                aspectRatio="16:9"
                loading="lazy"
                decoding="async"
              />
            )}
          </div>
        </div>
      ))
  }
  <div class="mt-2">
    <header>
      <h2
        class={`text-xl sm:text-2xl font-bold leading-tight mb-2 font-heading ${isNewsletter ? 'text-gray-900 dark:text-slate-100 border-b-2 border-gray-800 dark:border-gray-300 pb-2 tracking-tight' : 'text-gray-900 dark:text-slate-100'}`}
      >
        {
          link ? (
            <a
              class={`inline-block transition ease-in duration-200 ${isNewsletter ? 'hover:text-amber-900 dark:hover:text-amber-200' : 'hover:text-primary dark:hover:text-blue-700'}`}
              href={link}
            >
              {post.title}
            </a>
          ) : (
            post.title
          )
        }
      </h2>
      <div class="mb-1">
        <span
          class={`text-sm ${isNewsletter ? 'text-gray-800 dark:text-slate-200 font-medium uppercase tracking-wide' : 'text-gray-700 dark:text-slate-300'}`}
        >
          {
            isNewsletter && (
              <>
                <Icon name="tabler:news" class="w-4 h-4 inline-block -mt-0.5" /> Issue{' '}
                {String((post as Newsletter).issue).padStart(3, '0')} ·{' '}
              </>
            )
          }
          <Icon name="tabler:clock" class="w-3.5 h-3.5 inline-block -mt-0.5 dark:text-gray-400" />
          <time datetime={String(post.publishDate)} class="inline-block">{getFormattedDate(post.publishDate)}</time>
          {
            post.authors?.length && (
              <>
                {' '}
                ·{' '}
                <Icon
                  name={post.authors.length > 1 ? 'tabler:users' : 'tabler:user'}
                  class="w-3.5 h-3.5 inline-block -mt-0.5 dark:text-gray-400"
                />
                {post.authors.map((author, index) => (
                  <Fragment key={index}>
                    {index > 0 && ', '}
                    {author.url ? (
                      <a href={author.url} class="hover:underline">
                        <span>{author.name.replaceAll('-', ' ')}</span>
                      </a>
                    ) : (
                      <span>{author.name.replaceAll('-', ' ')}</span>
                    )}
                  </Fragment>
                ))}
              </>
            )
          }

          {
            isBlogPost &&
              (post as Post).category &&
              (() => {
                const category = (post as Post).category!;
                return (
                  <>
                    {' '}
                    ·{' '}
                    <a class="hover:underline" href={getPermalink(category.slug, 'category')}>
                      {category.title}
                    </a>
                  </>
                );
              })()
          }
        </span>
      </div>
      {
        isBlogPost && (post as Post).series && (
          <div class="mt-1.5 mb-1">
            <a
              href={getPermalink((post as Post).series!.slug, 'series')}
              class="inline-flex items-center gap-1 text-xs font-semibold px-2.5 py-0.5 rounded-full bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300 hover:bg-purple-200 dark:hover:bg-purple-900/60 transition-colors duration-150"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0l-4-4m4 4l-4 4" />
              </svg>
              Series: {(post as Post).series!.title}
            </a>
          </div>
        )
      }
    </header>

    {
      post.excerpt && (
        <p
          class={`flex-grow text-lg ${isNewsletter ? 'text-gray-800 dark:text-slate-300 leading-relaxed font-serif' : 'text-muted dark:text-slate-300'}`}
        >
          {post.excerpt}
        </p>
      )
    }
    {
      isBlogPost && (post as Post).tags && Array.isArray((post as Post).tags) ? (
        (() => {
          const visibleTags = sharedTagSlugs
            ? (post as Post).tags!.filter((t) => sharedTagSlugs.has(t.slug))
            : (post as Post).tags;
          return visibleTags && visibleTags.length > 0 ? (
            <footer class="mt-3">
              <PostTags tags={visibleTags} />
            </footer>
          ) : (
            <Fragment />
          );
        })()
      ) : (
        <Fragment />
      )
    }
  </div>
</article>
