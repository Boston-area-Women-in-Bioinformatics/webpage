---
/**
 * NewBadge Component
 * Displays a "New" pill badge, typically positioned absolute at -top-2 -left-2 on a relative parent.
 */
---

<span class="absolute -top-2 -left-2 z-10">
  <span
    class="absolute inset-0 rounded-full dark:animate-ping bg-green-500 dark:bg-green-500 opacity-75"
    style="animation-duration: 2s;"></span>
  <span
    class="relative bg-green-500 dark:bg-green-600 text-white text-xs font-bold uppercase tracking-wide px-2.5 py-1 rounded-full shadow-[0_0_10px_2px_rgba(34,197,94,0.6)] dark:shadow-none inline-block"
  >
    New
  </span>
</span>
