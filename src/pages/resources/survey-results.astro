---
import Layout from '~/layouts/PageLayout.astro';
import Button from '~/components/ui/Button.astro';
import { SITE } from '~/config/site/config.js';

const metadata = {
  title: `Survey Results - ${SITE.title}`,
  description:
    'Workforce demographics, career trajectories, compensation, and community engagement data from our survey of bioinformaticians across the United States.',
};
---

<Layout metadata={metadata}>
  <!-- Page Header -->
  <section class="py-12 md:py-16 text-center">
    <div class="mx-auto max-w-6xl px-4 md:px-6">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 leading-tight text-default dark:text-slate-100">
        Bioinformaticians in the US
      </h1>
      <p class="text-base sm:text-lg md:text-xl text-muted dark:text-slate-300 mb-2">
        A Survey of Workforce Demographics, Career Trajectories &amp; Compensation
      </p>
      <p class="text-sm text-muted dark:text-slate-400">260 respondents &nbsp;·&nbsp; Fully anonymous</p>
    </div>
  </section>

  <!-- Fact Banner -->
  <div
    class="bg-accent-warm text-white text-center py-3.5 px-6 text-sm font-semibold tracking-wide relative overflow-hidden"
  >
    <div
      class="absolute inset-0"
      style="background: repeating-linear-gradient(90deg,rgba(255,255,255,.04) 0px,rgba(255,255,255,.04) 1px,transparent 1px,transparent 40px);"
    >
    </div>
    <div class="relative flex items-center justify-center flex-wrap gap-4">
      <span class="inline-flex items-center gap-2 whitespace-nowrap">
        <span
          class="w-2 h-2 rounded-full bg-yellow-300 flex-shrink-0"
          style="box-shadow:0 0 0 0 rgba(253,224,71,.7);animation:pulse-dot 1.8s infinite;"></span>
        <strong>Did you know?</strong> Bioinformatician salaries range from under $80K to over $200K. Where do you fit?
      </span>
      <span class="opacity-40 hidden sm:inline">|</span>
      <a
        href="https://forms.gle/8fRqmTBeJCcFaLFo8"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-1.5 bg-slate-800 hover:bg-slate-700 text-white text-xs font-bold py-1.5 px-4 rounded-full transition-transform hover:-translate-y-px whitespace-nowrap no-underline"
      >
        <svg viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3 flex-shrink-0"
          ><path
            d="M8 0a8 8 0 100 16A8 8 0 008 0zm.75 4.75a.75.75 0 00-1.5 0v3.5H3.75a.75.75 0 000 1.5h3.5v3.5a.75.75 0 001.5 0v-3.5h3.5a.75.75 0 000-1.5h-3.5v-3.5z"
          ></path></svg
        >
        Add Your Data
      </a>
    </div>
  </div>

  <!-- Hero Stats -->
  <div class="bg-slate-800 dark:bg-slate-900 text-white py-12 px-6 text-center relative overflow-hidden">
    <div class="survey-hero-bg absolute inset-0 opacity-5"></div>
    <div class="relative mx-auto max-w-6xl">
      <img
        src="/photos/WIB_Logo.jpg"
        alt="Boston Women in Bioinformatics logo"
        class="w-24 h-24 object-contain block mx-auto mb-4 rounded-lg"
      />
      <span
        class="inline-block bg-white/10 border border-white/20 text-blue-300 text-xs font-semibold tracking-widest uppercase py-1 px-3.5 rounded-full mb-5"
      >
        Boston Women in Bioinformatics
      </span>
      <div class="flex justify-center flex-wrap gap-5 mb-8">
        <div class="bg-white/[.07] border border-white/10 rounded-2xl py-4 px-6 min-w-[130px]">
          <span class="block text-3xl font-extrabold text-accent-warm">260</span>
          <span class="block text-xs text-slate-400 mt-0.5">Total Responses</span>
        </div>
        <div class="bg-white/[.07] border border-white/10 rounded-2xl py-4 px-6 min-w-[130px]">
          <span class="block text-3xl font-extrabold text-accent-warm">80.4%</span>
          <span class="block text-xs text-slate-400 mt-0.5">Identify as Female</span>
        </div>
        <div class="bg-white/[.07] border border-white/10 rounded-2xl py-4 px-6 min-w-[130px]">
          <span class="block text-3xl font-extrabold text-accent-warm">69%</span>
          <span class="block text-xs text-slate-400 mt-0.5">Currently Employed</span>
        </div>
        <div class="bg-white/[.07] border border-white/10 rounded-2xl py-4 px-6 min-w-[130px]">
          <span class="block text-3xl font-extrabold text-accent-warm">29</span>
          <span class="block text-xs text-slate-400 mt-0.5">States Represented</span>
        </div>
        <div class="bg-white/[.07] border border-white/10 rounded-2xl py-4 px-6 min-w-[130px]">
          <span class="block text-3xl font-extrabold text-accent-warm">44%</span>
          <span class="block text-xs text-slate-400 mt-0.5">PhD or Higher</span>
        </div>
      </div>
      <Button
        variant="primary"
        href="https://forms.gle/8fRqmTBeJCcFaLFo8"
        target="_blank"
        rel="noopener"
        text="Take the Survey and Add Your Voice"
        icon="tabler:edit"
        class="bg-accent-warm hover:bg-orange-600 dark:hover:bg-lime-600 text-white border-accent-warm"
      />
      <p class="mt-3 text-xs text-slate-400">Takes ~3 minutes &nbsp;·&nbsp; Fully anonymous</p>
    </div>
  </div>

  <!-- Gate Overlay (shown when locked) -->
  <div id="survey-gate" class="hidden">
    <div class="mx-auto max-w-2xl px-4 py-16 text-center">
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-2xl p-10 shadow-lg">
        <div
          class="w-16 h-16 rounded-full bg-orange-50 dark:bg-orange-900/20 flex items-center justify-center text-3xl mx-auto mb-6"
        >
          🔒
        </div>
        <h2 class="text-2xl font-bold text-default dark:text-slate-100 mb-3">Add Your Data to Unlock Results</h2>
        <p class="text-muted dark:text-slate-300 mb-2">
          This dashboard is built from community contributions. To keep the data current and inclusive, we ask that you
          share your own information before viewing the full results.
        </p>
        <p class="text-sm text-muted dark:text-slate-400 mb-8">Takes ~3 minutes &nbsp;·&nbsp; Fully anonymous</p>
        <a
          href="https://forms.gle/8fRqmTBeJCcFaLFo8"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 bg-accent-warm hover:bg-orange-600 text-white font-bold py-3.5 px-8 rounded-full transition-colors no-underline text-base"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"></path><path
              d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg
          >
          Take the Survey
        </a>
        <div class="mt-6 pt-6 border-t border-gray-100 dark:border-slate-700">
          <p class="text-xs text-muted dark:text-slate-400 mb-3">Already submitted? Click below to unlock.</p>
          <button
            id="unlock-btn"
            class="text-sm font-semibold text-primary dark:text-blue-400 hover:underline bg-transparent border-none cursor-pointer"
          >
            I've already submitted my data →
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Dashboard (hidden until unlocked) -->
  <div id="survey-dashboard" class="hidden">
    <!-- Sticky Tab Nav -->
    <nav class="sticky top-0 z-50 bg-white dark:bg-slate-900 border-b border-gray-200 dark:border-slate-700 shadow-sm">
      <div class="flex overflow-x-auto scrollbar-none max-w-6xl mx-auto px-4">
        <button
          class="survey-tab-btn active flex-shrink-0 py-3.5 px-5 text-xs font-semibold text-muted dark:text-slate-400 border-b-[3px] border-transparent bg-transparent cursor-pointer transition-colors whitespace-nowrap"
          onclick="showSurveySection('s-demographics', this)">Demographics</button
        >
        <button
          class="survey-tab-btn flex-shrink-0 py-3.5 px-5 text-xs font-semibold text-muted dark:text-slate-400 border-b-[3px] border-transparent bg-transparent cursor-pointer transition-colors whitespace-nowrap"
          onclick="showSurveySection('s-education', this)">Education</button
        >
        <button
          class="survey-tab-btn flex-shrink-0 py-3.5 px-5 text-xs font-semibold text-muted dark:text-slate-400 border-b-[3px] border-transparent bg-transparent cursor-pointer transition-colors whitespace-nowrap"
          onclick="showSurveySection('s-career', this)">Career &amp; Compensation</button
        >
        <button
          class="survey-tab-btn flex-shrink-0 py-3.5 px-5 text-xs font-semibold text-muted dark:text-slate-400 border-b-[3px] border-transparent bg-transparent cursor-pointer transition-colors whitespace-nowrap"
          onclick="showSurveySection('s-companies', this)">Companies</button
        >
        <button
          class="survey-tab-btn flex-shrink-0 py-3.5 px-5 text-xs font-semibold text-muted dark:text-slate-400 border-b-[3px] border-transparent bg-transparent cursor-pointer transition-colors whitespace-nowrap"
          onclick="showSurveySection('s-expertise', this)">Expertise</button
        >
        <button
          class="survey-tab-btn flex-shrink-0 py-3.5 px-5 text-xs font-semibold text-muted dark:text-slate-400 border-b-[3px] border-transparent bg-transparent cursor-pointer transition-colors whitespace-nowrap"
          onclick="showSurveySection('s-community', this)">Community</button
        >
      </div>
    </nav>

    <!-- Dashboard Content -->
    <div class="bg-gray-50 dark:bg-slate-950 min-h-screen">
      <div class="mx-auto max-w-6xl px-4 md:px-6 py-8 md:py-12">
        <!-- DEMOGRAPHICS -->
        <section class="survey-section" id="s-demographics">
          <h2 class="text-2xl font-bold text-default dark:text-slate-100 mb-1">Demographics</h2>
          <p class="text-sm text-muted dark:text-slate-400 mb-7">
            Gender identity and geographic distribution of survey respondents.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-7">
            <div
              class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-5 flex items-center gap-4 shadow-sm"
            >
              <div
                class="w-12 h-12 rounded-xl bg-pink-50 dark:bg-pink-900/20 flex items-center justify-center text-2xl flex-shrink-0"
              >
                👩
              </div>
              <div>
                <div class="text-2xl font-extrabold text-default dark:text-slate-100 leading-none">209</div><div
                  class="text-xs text-muted dark:text-slate-400 mt-1"
                >
                  Identify as Female
                </div>
              </div>
            </div>
            <div
              class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-5 flex items-center gap-4 shadow-sm"
            >
              <div
                class="w-12 h-12 rounded-xl bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center text-2xl flex-shrink-0"
              >
                👨
              </div>
              <div>
                <div class="text-2xl font-extrabold text-default dark:text-slate-100 leading-none">48</div><div
                  class="text-xs text-muted dark:text-slate-400 mt-1"
                >
                  Identify as Male
                </div>
              </div>
            </div>
            <div
              class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-5 flex items-center gap-4 shadow-sm"
            >
              <div
                class="w-12 h-12 rounded-xl bg-green-50 dark:bg-green-900/20 flex items-center justify-center text-2xl flex-shrink-0"
              >
                📍
              </div>
              <div>
                <div class="text-2xl font-extrabold text-default dark:text-slate-100 leading-none">29</div><div
                  class="text-xs text-muted dark:text-slate-400 mt-1"
                >
                  States Represented
                </div>
              </div>
            </div>
            <div
              class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-5 flex items-center gap-4 shadow-sm"
            >
              <div
                class="w-12 h-12 rounded-xl bg-orange-50 dark:bg-orange-900/20 flex items-center justify-center text-2xl flex-shrink-0"
              >
                🏙️
              </div>
              <div>
                <div class="text-2xl font-extrabold text-default dark:text-slate-100 leading-none">65%</div><div
                  class="text-xs text-muted dark:text-slate-400 mt-1"
                >
                  Based in Massachusetts
                </div>
              </div>
            </div>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
            <div
              class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 shadow-sm"
            >
              <div class="text-sm font-bold text-default dark:text-slate-100 mb-1">Gender Identity</div>
              <div class="text-xs text-muted dark:text-slate-400 mb-5">n = 260</div>
              <div class="relative h-48"><canvas id="genderChart"></canvas></div>
            </div>
            <div
              class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 shadow-sm"
            >
              <div class="text-sm font-bold text-default dark:text-slate-100 mb-1">Geographic Distribution</div>
              <div class="text-xs text-muted dark:text-slate-400 mb-5">Top states represented (n = 255)</div>
              <ul class="s-bar-list list-none flex flex-col gap-2.5" id="locationBars"></ul>
            </div>
          </div>
          <div class="flex flex-wrap gap-4 mt-6">
            <div
              class="flex-1 basis-52 border-l-4 border-accent-warm bg-orange-50 dark:bg-slate-800 rounded-r-xl px-4 py-3.5 text-sm text-slate-800 dark:text-slate-200"
            >
              <strong>Massachusetts dominates:</strong> 165 of 255 respondents (65%) are based in MA, reflecting the survey's
              Boston roots.
            </div>
            <div
              class="flex-1 basis-52 border-l-4 border-accent-warm bg-orange-50 dark:bg-slate-800 rounded-r-xl px-4 py-3.5 text-sm text-slate-800 dark:text-slate-200"
            >
              <strong>National reach:</strong> Respondents span 29 states including CA, NY, TX, NJ, CT, PA, GA, MD, and DE.
            </div>
            <div
              class="flex-1 basis-52 border-l-4 border-accent-warm bg-orange-50 dark:bg-slate-800 rounded-r-xl px-4 py-3.5 text-sm text-slate-800 dark:text-slate-200"
            >
              <strong>Highly female:</strong> 80.4% of respondents identify as female, consistent with the community's focus
              on women in bioinformatics.
            </div>
          </div>
        </section>

        <!-- EDUCATION -->
        <section class="survey-section hidden" id="s-education">
          <h2 class="text-2xl font-bold text-default dark:text-slate-100 mb-1">Education</h2>
          <p class="text-sm text-muted dark:text-slate-400 mb-7">
            Highest degree attained, field of study, graduation era, and degree origin.
          </p>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
            <div
              class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 shadow-sm"
            >
              <div class="text-sm font-bold text-default dark:text-slate-100 mb-1">Highest Level of Education</div>
              <div class="text-xs text-muted dark:text-slate-400 mb-5">n = 260</div>
              <div class="relative h-64"><canvas id="educationChart"></canvas></div>
            </div>
            <div
              class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 shadow-sm"
            >
              <div class="text-sm font-bold text-default dark:text-slate-100 mb-1">Degree Concentration</div>
              <div class="text-xs text-muted dark:text-slate-400 mb-5">n = 260</div>
              <div class="relative h-64"><canvas id="concentrationChart"></canvas></div>
            </div>
            <div
              class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 shadow-sm"
            >
              <div class="text-sm font-bold text-default dark:text-slate-100 mb-1">Graduation Era</div>
              <div class="text-xs text-muted dark:text-slate-400 mb-5">n = 257 — graduation era for highest degree</div>
              <div class="relative h-48"><canvas id="gradYearChart"></canvas></div>
            </div>
            <div
              class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 shadow-sm"
            >
              <div class="text-sm font-bold text-default dark:text-slate-100 mb-1">Degree Origin</div>
              <div class="text-xs text-muted dark:text-slate-400 mb-5">n = 260</div>
              <div class="relative h-48"><canvas id="degreeOriginChart"></canvas></div>
            </div>
          </div>
          <div class="flex flex-wrap gap-4 mt-6">
            <div
              class="flex-1 basis-52 border-l-4 border-accent-warm bg-orange-50 dark:bg-slate-800 rounded-r-xl px-4 py-3.5 text-sm text-slate-800 dark:text-slate-200"
            >
              <strong>Masters &amp; PhD nearly even:</strong> 102 Masters vs 103 PhDs — the community spans both research
              and applied tracks.
            </div>
            <div
              class="flex-1 basis-52 border-l-4 border-accent-warm bg-orange-50 dark:bg-slate-800 rounded-r-xl px-4 py-3.5 text-sm text-slate-800 dark:text-slate-200"
            >
              <strong>Recent graduates:</strong> 62% earned their highest degree between 2020–2025, reflecting a young and
              growing workforce.
            </div>
            <div
              class="flex-1 basis-52 border-l-4 border-accent-warm bg-orange-50 dark:bg-slate-800 rounded-r-xl px-4 py-3.5 text-sm text-slate-800 dark:text-slate-200"
            >
              <strong>International talent:</strong> 20% received their degree outside the US, highlighting the global nature
              of bioinformatics talent.
            </div>
          </div>
        </section>

        <!-- CAREER -->
        <section class="survey-section hidden" id="s-career">
          <h2 class="text-2xl font-bold text-default dark:text-slate-100 mb-1">Career &amp; Compensation</h2>
          <p class="text-sm text-muted dark:text-slate-400 mb-7">
            Employment status, work arrangement, experience levels, and salary distribution.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-7">
            <div
              class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-5 flex items-center gap-4 shadow-sm"
            >
              <div
                class="w-12 h-12 rounded-xl bg-green-50 dark:bg-green-900/20 flex items-center justify-center text-2xl flex-shrink-0"
              >
                ✅
              </div>
              <div>
                <div class="text-2xl font-extrabold text-default dark:text-slate-100 leading-none">179</div><div
                  class="text-xs text-muted dark:text-slate-400 mt-1"
                >
                  Currently Employed
                </div>
              </div>
            </div>
            <div
              class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-5 flex items-center gap-4 shadow-sm"
            >
              <div
                class="w-12 h-12 rounded-xl bg-red-50 dark:bg-red-900/20 flex items-center justify-center text-2xl flex-shrink-0"
              >
                🔍
              </div>
              <div>
                <div class="text-2xl font-extrabold text-default dark:text-slate-100 leading-none">81</div><div
                  class="text-xs text-muted dark:text-slate-400 mt-1"
                >
                  Job Seeking
                </div>
              </div>
            </div>
            <div
              class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-5 flex items-center gap-4 shadow-sm"
            >
              <div
                class="w-12 h-12 rounded-xl bg-purple-50 dark:bg-purple-900/20 flex items-center justify-center text-2xl flex-shrink-0"
              >
                🏆
              </div>
              <div>
                <div class="text-2xl font-extrabold text-default dark:text-slate-100 leading-none">24%</div><div
                  class="text-xs text-muted dark:text-slate-400 mt-1"
                >
                  In Leadership Roles
                </div>
              </div>
            </div>
            <div
              class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-5 flex items-center gap-4 shadow-sm"
            >
              <div
                class="w-12 h-12 rounded-xl bg-orange-50 dark:bg-orange-900/20 flex items-center justify-center text-2xl flex-shrink-0"
              >
                💼
              </div>
              <div>
                <div class="text-2xl font-extrabold text-default dark:text-slate-100 leading-none">45%</div><div
                  class="text-xs text-muted dark:text-slate-400 mt-1"
                >
                  Hybrid Work
                </div>
              </div>
            </div>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
            <div
              class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 shadow-sm"
            >
              <div class="text-sm font-bold text-default dark:text-slate-100 mb-1">Employment Status</div>
              <div class="text-xs text-muted dark:text-slate-400 mb-5">n = 260</div>
              <div class="relative h-48"><canvas id="employmentChart"></canvas></div>
            </div>
            <div
              class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 shadow-sm"
            >
              <div class="text-sm font-bold text-default dark:text-slate-100 mb-1">Work Arrangement (Employed)</div>
              <div class="text-xs text-muted dark:text-slate-400 mb-5">n = 179</div>
              <div class="relative h-48"><canvas id="jobTypeChart"></canvas></div>
            </div>
            <div
              class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 shadow-sm"
            >
              <div class="text-sm font-bold text-default dark:text-slate-100 mb-1">Years of Post-Degree Experience</div>
              <div class="text-xs text-muted dark:text-slate-400 mb-5">n = 260</div>
              <div class="relative h-64"><canvas id="experienceChart"></canvas></div>
            </div>
            <div
              class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 shadow-sm"
            >
              <div class="text-sm font-bold text-default dark:text-slate-100 mb-1">Total Annual Compensation (USD)</div>
              <div class="text-xs text-muted dark:text-slate-400 mb-5">
                n = 168 — among currently employed respondents who shared salary
              </div>
              <div class="relative h-64"><canvas id="compensationChart"></canvas></div>
            </div>
          </div>
          <div
            class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 shadow-sm mt-5"
          >
            <div class="text-sm font-bold text-default dark:text-slate-100 mb-1">
              Job Search Duration (Unemployed Respondents)
            </div>
            <div class="text-xs text-muted dark:text-slate-400 mb-5">
              n = 80 — how long respondents have been searching
            </div>
            <div class="relative h-48"><canvas id="jobSearchChart"></canvas></div>
          </div>
          <div class="flex flex-wrap gap-4 mt-6">
            <div
