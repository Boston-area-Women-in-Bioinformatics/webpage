<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script is:inline>
  // ── GATE LOGIC ────────────────────────────────────────────────────
  (function () {
    const STORAGE_KEY = 'wib_survey_unlocked';
    const gate = document.getElementById('survey-gate');
    const dashboard = document.getElementById('survey-dashboard');

    function unlock() {
      localStorage.setItem(STORAGE_KEY, '1');
      gate.classList.add('hidden');
      dashboard.classList.remove('hidden');
      // strip the param from the URL cleanly
      const url = new URL(window.location.href);
      url.searchParams.delete('unlocked');
      window.history.replaceState({}, '', url.toString());
    }

    const params = new URLSearchParams(window.location.search);
    if (params.get('unlocked') === 'true' || localStorage.getItem(STORAGE_KEY) === '1') {
      unlock();
    } else {
      gate.classList.remove('hidden');
    }

    const unlockBtn = document.getElementById('unlock-btn');
    if (unlockBtn) {
      unlockBtn.addEventListener('click', unlock);
    }
  })();

  const WARM = '#e36d1d';
  const BLUE = '#0161ef';
  const PURPLE = '#6d28d9';
  const AMBER = '#f59e0b';
  const EMERALD = '#10b981';
  const ORANGE = '#fb923c';
  const SKY = '#0ea5e9';
  const ROSE = '#ec4899';
  const VIOLET = '#6366f1';
  const MULTI = [WARM, BLUE, AMBER, EMERALD, PURPLE, ORANGE, SKY, ROSE, VIOLET, '#94a3b8'];

  const DATA = {
    gender: { labels: ['Female', 'Male', 'Other / Prefer not to say'], values: [209, 48, 3] },
    location: {
      labels: ['MA', 'CA', 'NY', 'IN', 'TX', 'NJ', 'PA', 'CT', 'GA', 'MD', 'DE', 'Other'],
      values: [165, 20, 8, 7, 6, 5, 5, 4, 4, 3, 3, 25],
    },
    education: { labels: ['Bachelors', 'Masters', 'PhD', 'MD/PhD', 'Other'], values: [40, 102, 103, 10, 5] },
    concentration: {
      labels: [
        'Bioinformatics &\nComp. Biology',
        'Biology',
        'Computer\nScience',
        'Biophysics',
        'Biotechnology',
        'Biostatistics /\nEpidemiology',
        'Other',
      ],
      values: [148, 57, 4, 3, 5, 5, 38],
    },
    gradYear: { labels: ['Before 2010', '2010–2019', '2020–2025'], values: [20, 78, 159] },
    degreeOrigin: { labels: ['Within US', 'Outside US'], values: [207, 53] },
    employment: { labels: ['Employed', 'Job Seeking'], values: [179, 81] },
    jobType: { labels: ['Hybrid', 'In-person', 'Remote'], values: [81, 57, 41] },
    experience: { labels: ['0–1 years', '2–5 years', '5–8 years', '8+ years'], values: [68, 91, 38, 63] },
    compensation: {
      labels: ['< $80K', '$80K–$120K', '$121K–$150K', '$151K–$180K', '$181K–$200K', '> $200K'],
      values: [65, 39, 22, 4, 16, 22],
    },
    jobSearch: {
      labels: ['0–3 months', '3–6 months', '6–9 months', '9–12 months', 'Over 1 year'],
      values: [39, 21, 9, 5, 6],
    },
    companyType: {
      labels: ['Academia', 'Biotech', 'Big Pharma', 'Consulting/CRO', 'Private Non-profit', 'Other'],
      values: [68, 53, 18, 14, 13, 12],
    },
    companySize: { labels: ['0–100', '100–1,000', '1,000–10,000', 'Over 10,000'], values: [52, 31, 42, 47] },
    leadership: { labels: ['No', 'Yes'], values: [136, 43] },
    strategic: { labels: ['Yes', 'No'], values: [29, 14] },
    targetRole: { labels: ['Individual Contributor', 'Manager / Director'], values: [66, 11] },
    platforms: {
      labels: ['LinkedIn', 'Bluesky', 'X (Twitter)', 'Instagram', 'Email', 'Other'],
      values: [246, 32, 23, 7, 4, 8],
    },
    expertise: {
      labels: [
        'Computational Biology',
        'NGS Analysis',
        'Data Science',
        'Management',
        'Software Engineering',
        'Biostatistics',
        'AI / Machine Learning',
        'Structural Biology',
        'Statistical Genetics',
      ],
      values: [202, 189, 147, 47, 48, 48, 47, 35, 38],
    },
  };

  function pct(v, t) {
    return Math.round((v / t) * 100) + '%';
  }

  function donut(id, labels, values, colors) {
    const total = values.reduce(function (a, b) {
      return a + b;
    }, 0);
    new Chart(document.getElementById(id), {
      type: 'doughnut',
      data: {
        labels: labels,
        datasets: [{ data: values, backgroundColor: colors || MULTI, borderWidth: 2, borderColor: '#fff' }],
      },
      options: {
        cutout: '60%',
        plugins: {
          legend: { position: 'right', labels: { font: { size: 12 }, padding: 10, boxWidth: 14 } },
          tooltip: {
            callbacks: {
              label: function (ctx) {
                return ' ' + ctx.label + ': ' + ctx.raw + ' (' + pct(ctx.raw, total) + ')';
              },
            },
          },
        },
      },
    });
  }
  function hbar(id, labels, values, color) {
    new Chart(document.getElementById(id), {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [{ data: values, backgroundColor: color || WARM, borderRadius: 6, borderSkipped: false }],
      },
      options: {
        indexAxis: 'y',
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function (ctx) {
                return ' ' + ctx.raw;
              },
            },
          },
        },
        scales: {
          x: { grid: { color: '#f1f5f9' }, ticks: { font: { size: 11 } }, beginAtZero: true },
          y: { grid: { display: false }, ticks: { font: { size: 12 } } },
        },
      },
    });
  }
  function vbar(id, labels, values, colors) {
    const isArr = Array.isArray(colors);
    new Chart(document.getElementById(id), {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [
          {
            data: values,
            backgroundColor: isArr
              ? colors
              : values.map(function () {
                  return colors || WARM;
                }),
            borderRadius: 6,
            borderSkipped: false,
          },
        ],
      },
      options: {
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function (ctx) {
                return ' ' + ctx.raw;
              },
            },
          },
        },
        scales: {
          x: { grid: { display: false }, ticks: { font: { size: 11 } } },
          y: { grid: { color: '#f1f5f9' }, ticks: { font: { size: 11 } }, beginAtZero: true },
        },
      },
    });
  }
  function barList(containerId, labels, values, color) {
    const max = Math.max.apply(null, values);
    const ul = document.getElementById(containerId);
    labels.forEach(function (lbl, i) {
      const li = document.createElement('li');
      li.className = 's-bar-item';
      li.innerHTML =
        '<div class="s-bl-label"><span>' +
        lbl +
        '</span><span>' +
        values[i] +
        '</span></div><div class="s-bar-track"><div class="s-bar-fill" style="width:' +
        (values[i] / max) * 100 +
        '%;background:' +
        (color || WARM) +
        '"></div></div>';
      ul.appendChild(li);
    });
  }

  donut('genderChart', DATA.gender.labels, DATA.gender.values, [WARM, BLUE, PURPLE, '#94a3b8']);
  barList('locationBars', DATA.location.labels, DATA.location.values, WARM);
  vbar('educationChart', DATA.education.labels, DATA.education.values, MULTI);
  donut('concentrationChart', DATA.concentration.labels, DATA.concentration.values);
  vbar('gradYearChart', DATA.gradYear.labels, DATA.gradYear.values, ['#bfdbfe', '#93c5fd', '#60a5fa', BLUE]);
  donut('degreeOriginChart', DATA.degreeOrigin.labels, DATA.degreeOrigin.values, [WARM, '#94a3b8']);
  donut('employmentChart', DATA.employment.labels, DATA.employment.values, [EMERALD, WARM]);
  donut('jobTypeChart', DATA.jobType.labels, DATA.jobType.values, [WARM, BLUE, SKY]);
  vbar('experienceChart', DATA.experience.labels, DATA.experience.values, WARM);
  vbar('compensationChart', DATA.compensation.labels, DATA.compensation.values, [
    '#bfdbfe',
    '#93c5fd',
    WARM,
    ORANGE,
    AMBER,
    '#1e3a5f',
  ]);
  vbar('jobSearchChart', DATA.jobSearch.labels, DATA.jobSearch.values, BLUE);
  donut('companyTypeChart', DATA.companyType.labels, DATA.companyType.values);
  vbar('companySizeChart', DATA.companySize.labels, DATA.companySize.values, ['#bfdbfe', '#60a5fa', BLUE, '#1e3a5f']);
  donut('leadershipChart', DATA.leadership.labels, DATA.leadership.values, ['#94a3b8', WARM]);
  donut('strategicChart', DATA.strategic.labels, DATA.strategic.values, [EMERALD, '#94a3b8']);
  donut('targetRoleChart', DATA.targetRole.labels, DATA.targetRole.values, [WARM, BLUE, PURPLE]);
  barList('platformBars', DATA.platforms.labels, DATA.platforms.values, BLUE);
  hbar('platformChart', DATA.platforms.labels, DATA.platforms.values, BLUE);
  hbar('expertiseChart', DATA.expertise.labels, DATA.expertise.values, WARM);

  // eslint-disable-next-line @typescript-eslint/no-unused-vars
  function showSurveySection(id, btn) {
    document.querySelectorAll('.survey-section').forEach(function (s) {
      s.classList.add('hidden');
    });
    document.querySelectorAll('.survey-tab-btn').forEach(function (b) {
      b.classList.remove('active', 'text-accent-warm', 'border-accent-warm');
      b.classList.add('text-muted', 'border-transparent');
    });
    document.getElementById(id).classList.remove('hidden');
    btn.classList.add('active', 'text-accent-warm', 'border-accent-warm');
    btn.classList.remove('text-muted', 'border-transparent');
  }
  // init first tab active state
  (function () {
    const first = document.querySelector('.survey-tab-btn');
    if (first) {
      first.classList.add('text-accent-warm', 'border-accent-warm');
      first.classList.remove('text-muted', 'border-transparent');
    }
  })();
</script>

<style is:global>
  .survey-hero-bg {
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-rule='evenodd'%3E%3Ccircle cx='30' cy='30' r='2'/%3E%3C/g%3E%3C/svg%3E");
  }
  @keyframes pulse-dot {
    0% {
      box-shadow: 0 0 0 0 rgba(253, 224, 71, 0.7);
    }
    70% {
      box-shadow: 0 0 0 8px rgba(253, 224, 71, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(253, 224, 71, 0);
    }
  }
  /* Bar list items created dynamically by JS */
  .s-bar-item {
    font-size: 13px;
  }
  .s-bl-label {
    display: flex;
    justify-content: space-between;
    margin-bottom: 3px;
    color: inherit;
  }
  .s-bl-label span:last-child {
    color: var(--aw-color-text-muted);
    font-variant-numeric: tabular-nums;
  }
  .s-bar-track {
    height: 8px;
    background: #f1f5f9;
    border-radius: 99px;
    overflow: hidden;
  }
  .dark .s-bar-track {
    background: rgb(51 65 85);
  }
  .s-bar-fill {
    height: 100%;
    border-radius: 99px;
    transition: width 0.6s ease;
  }
  /* Hide scrollbar on tab nav */
  nav .scrollbar-none {
    scrollbar-width: none;
  }
  nav .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
</style>
