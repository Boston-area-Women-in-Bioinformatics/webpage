---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';

export const prerender = true;

const now = new Date();
const allPastEvents = (
  await getCollection('event', ({ data }: CollectionEntry<'event'>) => {
    const eventEnd = data.endDate ? new Date(data.endDate) : new Date(data.dateTime);
    return eventEnd < now;
  })
).sort((a, b) => b.data.dateTime.valueOf() - a.data.dateTime.valueOf());

const eventsForClient = allPastEvents.map((e) => ({
  id: e.id,
  title: e.data.title,
  tags: e.data.tags || [],
  dateTime: e.data.dateTime.toISOString(),
  endDate: e.data.endDate?.toISOString() ?? null,
  location: e.data.location || [],
  imageSrc: e.data.image.src,
  imageAlt: e.data.image.alt,
  imgpos: e.data.imgpos ?? '',
  href: `/events/${e.id}`,
  isPartner: e.data.partnerEvent ?? false,
  partnerOrganization: e.data.partnerOrganization ?? null,
}));

const metadata = {
  title: 'Past Events',
  description: 'Browse our archive of past bioinformatics workshops, networking events, and casual meetups',
};
---

<Layout metadata={metadata}>
  <section class="px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-7xl">
    <div class="mb-5">
      <a
        href="/events"
        class="inline-flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-primary dark:hover:text-primary transition-colors duration-200"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Events
      </a>
    </div>

    <Headline title="Past Events Archive" subtitle="Browse our history of bioinformatics events and meetups" />

    <!-- Search, Date Range, and Sort Controls -->
    <div class="flex flex-col gap-3 mb-6">
      <div class="flex flex-col sm:flex-row gap-3">
        <!-- Search -->
        <div class="relative flex-1">
          <label for="event-search" class="sr-only">Search events</label>
          <input
            id="event-search"
            type="search"
            placeholder="Search by title or tag..."
            class="w-full pl-10 pr-4 py-2 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-gray-900 dark:text-slate-100 placeholder-gray-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-primary"
            autocomplete="off"
          />
          <svg
            class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 dark:text-slate-500 pointer-events-none"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"></path>
          </svg>
        </div>
        <!-- Sort -->
        <div>
          <label for="event-sort" class="sr-only">Sort events</label>
          <select
            id="event-sort"
            class="py-2 px-4 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-gray-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-primary"
          >
            <option value="newest">Newest First</option>
            <option value="oldest">Oldest First</option>
            <option value="az">Title A–Z</option>
            <option value="za">Title Z–A</option>
          </select>
        </div>
      </div>
      <!-- Date Range -->
      <div class="flex flex-col sm:flex-row gap-3 items-center">
        <div class="flex items-center gap-2 flex-1">
          <label for="date-start" class="text-sm text-gray-600 dark:text-slate-400 whitespace-nowrap">From</label>
          <input
            id="date-start"
            type="date"
            min="2024-08-08"
            class="flex-1 py-2 px-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-gray-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-primary"
          />
        </div>
        <div class="flex items-center gap-2 flex-1">
          <label for="date-end" class="text-sm text-gray-600 dark:text-slate-400 whitespace-nowrap">To</label>
          <input
            id="date-end"
            type="date"
            min="2024-08-08"
            class="flex-1 py-2 px-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-gray-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-primary"
          />
        </div>
        <div class="flex items-center gap-3">
          <label class="flex items-center gap-2 cursor-pointer select-none">
            <input
              id="hide-partner"
              type="checkbox"
              class="w-4 h-4 rounded border-gray-300 dark:border-slate-600 text-primary focus:ring-primary"
            />
            <span class="text-sm text-gray-600 dark:text-slate-400 whitespace-nowrap">Hide partner events</span>
          </label>
          <button
            id="clear-filters"
            class="text-sm text-primary dark:text-blue-400 hover:underline whitespace-nowrap hidden"
          >
            Clear filters
          </button>
        </div>
      </div>
    </div>

    <!-- Results -->
    <div id="search-results-list" class="grid grid-cols-1 gap-6 mb-8 md:mt-3 md:mb-12"></div>
    <p id="no-results" class="hidden text-center text-gray-500 dark:text-slate-400 py-12 text-lg">
      No events found matching your filters.
    </p>
  </section>
</Layout>

<script is:inline define:vars={{ eventsForClient }}>
  const searchInput = document.getElementById('event-search');
  const sortSelect = document.getElementById('event-sort');
  const dateStart = document.getElementById('date-start');
  const dateEnd = document.getElementById('date-end');
  const hidePartnerCheckbox = document.getElementById('hide-partner');
  const clearBtn = document.getElementById('clear-filters');
  const searchResultsList = document.getElementById('search-results-list');
  const noResults = document.getElementById('no-results');

  // Set max date to today and default values
  const todayStr = new Date().toISOString().split('T')[0];
  dateStart.max = todayStr;
  dateEnd.max = todayStr;
  dateStart.value = '2024-08-08';
  dateEnd.value = todayStr;

  function formatDate(isoString) {
    const d = new Date(isoString);
    return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
  }

  function renderEventCard(event) {
    const tagsHtml =
      event.tags && event.tags.length > 0
        ? `<div class="flex flex-wrap gap-1 mb-4">${event.tags
            .map(
              (t) =>
                `<span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-slate-700 text-gray-600 dark:text-slate-300">${t}</span>`
            )
            .join('')}</div>`
        : '';

    const locationHtml =
      event.location && event.location.length > 0
        ? `<div class="text-sm mb-4 text-gray-700 dark:text-slate-300">${event.location.join(', ')}</div>`
        : '';

    const partnerBadge = event.isPartner
      ? `<span class="text-xs font-medium text-gray-500 dark:text-slate-400 italic mb-1 block">Hosted by ${event.partnerOrganization || 'Partner Organization'}</span>`
      : '';

    return `
      <div class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-700 shadow overflow-hidden flex flex-col md:flex-row">
        <img src="${event.imageSrc}" alt="${event.imageAlt}" class="w-full md:h-48 md:w-48 h-auto object-cover ${event.imgpos}" loading="lazy" />
        <div class="p-4 flex-1">
          ${partnerBadge}
          <h3 class="text-xl font-semibold mb-2 text-gray-900 dark:text-slate-100">${event.title}</h3>
          <div class="text-sm mb-4 text-gray-700 dark:text-slate-300">${formatDate(event.dateTime)}</div>
          ${locationHtml}
          ${tagsHtml}
          <a href="${event.href}" class="inline-block px-4 py-2 text-sm font-semibold rounded-lg bg-primary text-white hover:bg-blue-700 transition">MORE INFO</a>
        </div>
      </div>`;
  }

  const DEFAULT_START = '2024-08-08';

  function hasActiveFilters() {
    return (
      searchInput.value.trim().length > 0 ||
      sortSelect.value !== 'newest' ||
      dateStart.value !== DEFAULT_START ||
      dateEnd.value !== todayStr ||
      hidePartnerCheckbox.checked
    );
  }

  function updateDisplay() {
    const query = searchInput.value.trim().toLowerCase();
    const sort = sortSelect.value;
    const startVal = dateStart.value;
    const endVal = dateEnd.value;
    const hidePartner = hidePartnerCheckbox.checked;

    // Show/hide clear button
    clearBtn.classList.toggle('hidden', !hasActiveFilters());

    let results = eventsForClient.filter((e) => !hidePartner || !e.isPartner);

    if (query) {
      results = results.filter(
        (e) => e.title.toLowerCase().includes(query) || e.tags.some((t) => t.toLowerCase().includes(query))
      );
    }

    if (startVal) {
      const start = new Date(startVal);
      results = results.filter((e) => new Date(e.dateTime) >= start);
    }

    if (endVal) {
      // Include events on the end date by going to end of that day
      const end = new Date(endVal);
      end.setHours(23, 59, 59, 999);
      results = results.filter((e) => new Date(e.dateTime) <= end);
    }

    results = [...results].sort((a, b) => {
      if (sort === 'newest') return new Date(b.dateTime) - new Date(a.dateTime);
      if (sort === 'oldest') return new Date(a.dateTime) - new Date(b.dateTime);
      if (sort === 'az') return a.title.localeCompare(b.title);
      if (sort === 'za') return b.title.localeCompare(a.title);
      return 0;
    });

    if (results.length === 0) {
      searchResultsList.innerHTML = '';
      noResults.classList.remove('hidden');
    } else {
      noResults.classList.add('hidden');
      searchResultsList.innerHTML = results.map(renderEventCard).join('');
    }
  }

  function clearFilters() {
    searchInput.value = '';
    sortSelect.value = 'newest';
    dateStart.value = DEFAULT_START;
    dateEnd.value = todayStr;
    hidePartnerCheckbox.checked = false;
    updateDisplay();
  }

  searchInput.addEventListener('input', updateDisplay);
  sortSelect.addEventListener('change', updateDisplay);
  dateStart.addEventListener('change', updateDisplay);
  dateEnd.addEventListener('change', updateDisplay);
  hidePartnerCheckbox.addEventListener('change', updateDisplay);
  clearBtn.addEventListener('click', clearFilters);

  // Render all events on initial load
  updateDisplay();
</script>
