---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from '~/config/site/config.js';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
//import eventImg from '~/../public/photos/2025/WIB_10Year_group_photo1.jpg'; // adjust path as needed
//import AddToCalendarButton from '~/components/AddToCalendarButton.tsx';
import Button from '~/components/ui/Button.astro';
import Card from '~/components/ui/Card.astro';
import UpcomingEvents from '~/components/widgets/UpcomingEvents.astro';
import { findLatestNewsletters } from '~/utils/newsletter';
import { findLatestPosts } from '~/utils/blog';
import { getCollection } from 'astro:content';
import { APP_NEWSLETTER, APP_BLOG } from 'astrowind:config';
import { getBlogPermalink } from '~/utils/permalinks';
import Image from '~/components/common/Image.astro';
import NewBadge from '~/components/ui/NewBadge.astro';

const latestNewsletter = APP_NEWSLETTER.isEnabled ? (await findLatestNewsletters({ count: 1 }))[0] : null;
const allLatestPosts = APP_BLOG.isEnabled ? (await findLatestPosts({ count: 20 })) || [] : [];
const latestPodcast = allLatestPosts.find((p) => p.category?.slug === 'podcast') || null;
const nonPodcastPosts = allLatestPosts.filter((p) => p.category?.slug !== 'podcast');

// Build a map of series slug → series image/alt from the series collection
const seriesEntries = await getCollection('series');
const seriesImageMap = new Map<string, { image?: string; imageAlt?: string; imageFit?: string }>();
seriesEntries.forEach((entry) => {
  const slug = entry.id.replace(/\.md$/, '');
  seriesImageMap.set(slug, { image: entry.data.image, imageAlt: entry.data.imageAlt, imageFit: entry.data.imageFit });
});

// Build a map of series slug → 2 most recent posts
const seriesPostsMap = new Map<string, typeof nonPodcastPosts>();
nonPodcastPosts.forEach((p) => {
  if (p.series?.slug) {
    const existing = seriesPostsMap.get(p.series.slug) ?? [];
    if (existing.length < 2) seriesPostsMap.set(p.series.slug, [...existing, p]);
  }
});

const seenSeries = new Set<string>();
const latestMediaPosts = nonPodcastPosts
  .filter((p) => {
    if (p.series?.slug) {
      if (seenSeries.has(p.series.slug)) return false;
      seenSeries.add(p.series.slug);
    }
    return true;
  })
  .slice(0, 4);

const thirtyDaysAgo = new Date();
thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);

const newsletterDate = latestNewsletter?.publishDate ? new Date(latestNewsletter.publishDate) : new Date(0);
const podcastDate = latestPodcast?.publishDate ? new Date(latestPodcast.publishDate) : new Date(0);
const podcastFirst = podcastDate > newsletterDate;

const metadata = {
  title: SITE.title,
  description: SITE.description,
};
---

<Layout metadata={metadata}>
  <!-- Hero Introduction Section -->
  <section class="py-16 md:py-20 bg-white dark:bg-dark">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl sm:text-5xl md:text-6xl dark:text-gray-100 font-bold mb-4 leading-tight">
        Boston Women in
        <span class="text-accent dark:text-gray-100 highlight">Bioinformatics</span>
      </h1>
      <p class="text-lg sm:text-xl text-gray-700 dark:text-gray-300">
        Advancing Women in Bioinformatics by Creating Networks of Support, Collaboration, and Empowerment.
      </p>
    </div>
  </section>

  <!-- Career Mentorship Program Call to Action -->
  <section class="py-10 md:py-14 bg-gray-50 dark:bg-slate-800">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <Hero2
        title="Career Mentorship Program"
        subtitle="Empowering women in bioinformatics to advance into leadership roles across academia and industry."
        tagline="2025-2026 Cohort Matches Are Out!"
        imageBefore={false}
        imageGap="lg:gap-8"
        padding="py-8 md:py-10 lg:py-0"
        image={{
          src: 'https://images.unsplash.com/photo-1553028826-f4804a6dba3b?q=80&w=870&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D',
          alt: 'A group of women work together at a wooden table with laptops and papers.',
        }}
        imageCitation='Photo by <a href="https://unsplash.com/@cowomen?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText">CoWomen</a> on <a href="https://unsplash.com/photos/a-group-of-people-sitting-around-a-wooden-table-ZKHksse8tUU?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText">Unsplash</a>'
      >
        <Fragment slot="content">
          <div class="text-center lg:text-left mb-6">
            <p class="text-lg text-gray-700 dark:text-gray-300 mb-4">
              The mentor-mentee matches for our 2025-2026 cohort have been sent out! Check your email for your match
              details and next steps.
            </p>
          </div>
          <div class="mt-6 text-center lg:text-left">
            <a
              href="/resources/career-mentorship"
              class="text-primary dark:text-blue-400 hover:underline text-sm font-medium"
            >
              Learn more about the program →
            </a>
          </div>
        </Fragment>
      </Hero2>
    </div>
  </section>

  <!-- Upcoming Events Section -->
  <section class="py-10 md:py-14 bg-white dark:bg-dark dark:text-gray-200">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <UpcomingEvents />
    </div>
  </section>

  <!-- From Our Committees Section (Newsletter + Podcast) -->
  <section class="py-10 md:py-14 bg-gray-50 dark:bg-slate-800 dark:text-gray-200">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl mb-8 text-center">Updates</h2>
      <div class="grid md:grid-cols-2 gap-8 md:items-stretch">
        <!-- Newsletter Column -->
        {
          latestNewsletter &&
            (() => {
              const isRemoteNewsletterImage =
                typeof latestNewsletter.image === 'string' &&
                (latestNewsletter.image.startsWith('http') ||
                  latestNewsletter.image.startsWith('/assets/') ||
                  latestNewsletter.image.startsWith('/blog_images/') ||
                  latestNewsletter.image.startsWith('/photos/'));
              return (
                <article
                  aria-labelledby="latest-newsletter-heading"
                  class={`flex flex-col h-full ${podcastFirst ? 'md:order-last' : ''}`}
                >
                  <h3 id="latest-newsletter-heading" class="text-2xl font-bold mb-4">
                    Communications
                  </h3>
                  <div class="relative flex flex-col flex-1">
                    {new Date(latestNewsletter.publishDate) >= thirtyDaysAgo && <NewBadge />}
                    <Card variant="blog" padding="p-0" class="flex flex-col flex-1">
                      {latestNewsletter.image && (
                        <a
                          href={latestNewsletter.permalink}
                          aria-label={`Read newsletter: ${latestNewsletter.excerpt?.slice(0, 60) || latestNewsletter.title}`}
                          class="block"
                        >
                          {isRemoteNewsletterImage ? (
                            <img
                              src={latestNewsletter.image}
                              alt={
                                latestNewsletter.imageAlt ||
                                latestNewsletter.excerpt?.slice(0, 100) ||
                                latestNewsletter.title
                              }
                              width="600"
                              height="400"
                              class="w-full h-64 object-cover"
                              loading="lazy"
                            />
                          ) : (
                            <Image
                              src={latestNewsletter.image}
                              alt={
                                latestNewsletter.imageAlt ||
                                (latestNewsletter.excerpt ? latestNewsletter.excerpt.slice(0, 100) : null) ||
                                latestNewsletter.title ||
                                'Newsletter image'
                              }
                              class="w-full h-64 object-cover"
                              widths={[400, 600]}
                              width={600}
                              height={400}
                              sizes="(max-width: 768px) 100vw, 50vw"
                              loading="lazy"
                            />
                          )}
                        </a>
                      )}
                      <div class="p-6">
                        <h4 class="text-xl font-bold mb-3">
                          <a
                            href={latestNewsletter.permalink}
                            class="hover:text-primary dark:hover:text-blue-700 transition ease-in duration-200"
                          >
                            {latestNewsletter.title}
                          </a>
                        </h4>
                        {latestNewsletter.excerpt && (
                          <p class="text-muted dark:text-slate-300 text-base mb-4">{latestNewsletter.excerpt}</p>
                        )}
                        <Button variant="link" href={latestNewsletter.permalink}>
                          Read more »
                        </Button>
                      </div>
                    </Card>
                  </div>
                </article>
              );
            })()
        }

        <!-- Latest Podcast Column -->
        {
          latestPodcast &&
            (() => {
              const isRemotePodcastImage =
                typeof latestPodcast.image === 'string' &&
                (latestPodcast.image.startsWith('http') ||
                  latestPodcast.image.startsWith('/assets/') ||
                  latestPodcast.image.startsWith('/blog_images/') ||
                  latestPodcast.image.startsWith('/photos/'));
              return (
                <article
                  aria-labelledby="latest-podcast-heading"
                  class={`flex flex-col h-full ${podcastFirst ? 'md:order-first' : ''}`}
                >
                  <h3 id="latest-podcast-heading" class="text-2xl font-bold mb-4">
                    Podcast
                  </h3>
                  <div class="relative flex flex-col flex-1">
                    {new Date(latestPodcast.publishDate) >= thirtyDaysAgo && <NewBadge />}
                    <Card variant="blog" padding="p-0" class="flex flex-col flex-1">
                      {latestPodcast.image && (
                        <a href={latestPodcast.permalink} class="block">
                          {isRemotePodcastImage ? (
                            <img
                              src={latestPodcast.image}
                              alt={latestPodcast.imageAlt || latestPodcast.title}
                              class="w-full h-64 object-contain"
                              loading="lazy"
                            />
                          ) : (
                            <Image
                              src={latestPodcast.image}
                              alt={latestPodcast.imageAlt || latestPodcast.title || 'Podcast image'}
                              class="w-full h-64 object-contain"
                              widths={[400, 600]}
                              width={600}
                              height={600}
                              sizes="(max-width: 768px) 100vw, 50vw"
                              loading="lazy"
                            />
                          )}
                        </a>
                      )}
                      <div class="p-6">
                        <p class="text-xs font-semibold uppercase tracking-wide text-muted dark:text-slate-400 mb-2">
                          Latest Episode
                        </p>
                        <h4 class="text-xl font-bold mb-3">
                          <a
                            href={latestPodcast.permalink}
                            class="hover:text-primary dark:hover:text-blue-700 transition ease-in duration-200"
                          >
                            {latestPodcast.title}
                          </a>
                        </h4>
                        {latestPodcast.excerpt && (
                          <p class="text-muted dark:text-slate-300 text-base mb-4">{latestPodcast.excerpt}</p>
                        )}
                        <Button variant="link" href={latestPodcast.permalink}>
                          Listen now »
                        </Button>
                      </div>
                    </Card>
                  </div>
                </article>
              );
            })()
        }
      </div>
    </div>
  </section>

  <!-- Latest from Our Community Section (blogs + videos) -->
  <section class="py-10 md:py-14 bg-white dark:bg-dark dark:text-gray-200">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl mb-4 text-center">Latest from Our Community</h2>
      <p class="text-center text-gray-500 dark:text-gray-400 mb-8">
        Dive into the latest blogs, videos, and conversations from our members
      </p>
      <div class="grid grid-cols-2 gap-6">
        {
          latestMediaPosts.map((post) => {
            const seriesMeta = post.series?.slug ? seriesImageMap.get(post.series.slug) : undefined;
            const cardImage = seriesMeta?.image ?? post.image;
            const cardImageAlt = seriesMeta?.imageAlt ?? post.imageAlt;
            const cardImageFit = seriesMeta?.imageFit ?? 'cover';
            const objectPosition =
              post.imagePosition === 'top' ? 'top' : post.imagePosition === 'bottom' ? 'bottom' : 'center';
            const isRemoteImage =
              typeof cardImage === 'string' &&
              (cardImage.startsWith('http') ||
                cardImage.startsWith('/assets/') ||
                cardImage.startsWith('/blog_images/'));
            const isNew = new Date(post.publishDate) >= thirtyDaysAgo;
            return (
              <div class="relative">
                {isNew && <NewBadge />}
                <Card variant="blog" padding="p-0">
                  {cardImage && (
                    <a href={post.series ? `/series/${post.series.slug}` : post.permalink} class="block">
                      {isRemoteImage ? (
                        <img
                          src={cardImage}
                          alt={cardImageAlt}
                          class={`w-full h-48 object-${cardImageFit}`}
                          style={`object-position: ${objectPosition};`}
                          loading="lazy"
                        />
                      ) : (
                        <Image
                          src={cardImage}
                          alt={cardImageAlt || post.title || 'Post image'}
                          class={`w-full h-48 object-${cardImageFit}`}
                          style={`object-position: ${objectPosition};`}
                          widths={[400, 600]}
                          width={600}
                          height={400}
                          sizes="(max-width: 768px) 50vw, 50vw"
                          loading="lazy"
                        />
                      )}
                    </a>
                  )}
                  <div class="p-3">
                    {post.series ? (
                      <>
                        <span class="inline-block text-xs font-semibold text-primary dark:text-blue-400 uppercase tracking-wide mb-1">
                          Series: {post.series.title}
                        </span>
                        <ul class="mt-1 space-y-1">
                          {(seriesPostsMap.get(post.series.slug) ?? []).map((sp) => (
                            <li class="text-xs">
                              <a
                                href={sp.permalink}
                                class="font-semibold hover:text-primary dark:hover:text-blue-400 transition ease-in duration-200"
                              >
                                {sp.title}
                              </a>
                            </li>
                          ))}
                        </ul>
                      </>
                    ) : (
                      <>
                        <h4 class="text-sm font-bold leading-tight mb-1">
                          <a
                            href={post.permalink}
                            class="hover:text-primary dark:hover:text-blue-700 transition ease-in duration-200"
                          >
                            {post.title}
                          </a>
                        </h4>
                        {post.excerpt && (
                          <p class="text-muted dark:text-slate-300 text-xs line-clamp-2">{post.excerpt}</p>
                        )}
                      </>
                    )}
                  </div>
                </Card>
              </div>
            );
          })
        }
      </div>
      <div class="text-center mt-6">
        <Button variant="link" href={getBlogPermalink()}>View all posts »</Button>
      </div>
    </div>
  </section>

  <!-- Community Survey Section -->
  <section class="py-16 md:py-20 bg-blue-50 dark:bg-blue-950 border-l-4 border-primary">
    <CallToAction
      title="Help Us Close the Gender Gap<br/><span class='text-2xl font-normal'>(and win a $25 gift card!)</span>"
      actions={[
        {
          variant: 'primary',
          target: '_blank',
          text: 'Fill out our survey',
          href: 'https://forms.gle/jhKy3hpYPf1WtC2s8',
          icon: 'tabler:checkbox',
        },
        {
          variant: 'secondary',
          target: '_blank',
          text: 'Check out our dashboard',
          href: 'https://bwib-advocacy-survey.netlify.app/',
          icon: 'tabler:chart-bar',
          class: '!bg-pink-700 !border-pink-700 hover:!bg-pink-800',
        },
      ]}
    >
      <Fragment slot="subtitle">
        <p class="text-gray-700 dark:text-slate-300 mb-6">
          Our data already shows it: <span class="text-primary dark:text-white font-semibold">21% of men</span> vs. <span
            class="text-primary dark:text-white font-semibold">14% of women</span
          > report holding leadership positions.<br />
          Help us build the evidence base our community deserves.
        </p>
        <ul class="text-gray-700 dark:text-slate-300 text-base space-y-2 mb-2 inline-block text-left">
          <li>✅ Takes ~5 minutes &amp; all responses are anonymous</li>
          <li>🎁 Every 100 new responses, we raffle a $25 gift card</li>
          <li>📢 Share with colleagues, collaborators, and friends</li>
        </ul>
      </Fragment>
    </CallToAction>
  </section>

  <!-- Let's Connect Section -->
  <section class="py-10 md:py-14 bg-gray-50 dark:bg-slate-800 dark:text-gray-200">
    <Features2
      title="Let's Connect!"
      subtitle="Join our community and stay in touch"
      columns={2}
      classes={{
        headline: {
          title: 'text-3xl font-bold tracking-tight sm:text-4xl mb-4',
          subtitle: 'text-xl dark:text-gray-200',
        },
      }}
      items={[
        // {
        //   title: 'General support',
        //   description: `Chat with us for inquiries related to account management, website navigation, payment issues, accessing purchased templates or general questions about the website's functionality.`,
        // },
        // {
        //   title: 'Contact sales',
        //   description:
        //     'Chat with us for questions about purchases, customization options, licensing for commercial use, inquiries about specific template, etc.',
        // },
        // {
        //   title: 'Technical support',
        //   description:
        //     'Chat with us when facing issues like template installation, problems editing difficulties, compatibility issues with software or download errors, or other technical challenges related to using the templates.',
        // },
        {
          title: 'Slack',
          description: 'Join our Slack community',
          icon: 'tabler:brand-slack',
          callToAction: {
            target: '_blank',
            href: 'https://join.slack.com/t/boston-women-bioinfo/shared_invite/zt-2y78bc7n7-W4TE7kuz8HGz4pzShTeZMQ',
          },
        },
        {
          title: 'Email',
          description: 'Reach out to our team',
          icon: 'tabler:mail',
          callToAction: {
            target: '_blank',
            href: 'mailto:communications@boston-wib.org',
          },
        },
        {
          title: 'LinkedIn',
          description: 'Connect with us on LinkedIn',
          icon: 'tabler:brand-linkedin',
          callToAction: {
            target: '_blank',
            href: 'https://www.linkedin.com/groups/13074137/',
          },
        },
        {
          title: 'Events Calendar',
          description: 'View our upcoming events',
          icon: 'tabler:calendar-event',
          callToAction: {
            target: '_blank',
            href: 'https://luma.com/bwib',
          },
        },
      ]}
    />
  </section>
