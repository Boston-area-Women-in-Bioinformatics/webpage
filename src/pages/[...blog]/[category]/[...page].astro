---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';
import { blogCategoryRobots, getStaticPathsBlogCategory } from '~/utils/blog';
import { getPermalink } from '~/utils/permalinks';

import Layout from '~/layouts/PageLayout.astro';
import PostListItem from '~/components/ui/PostListItem.astro';
import Headline from '~/components/ui/Headline.astro';
import Pagination from '~/components/blog/Pagination.astro';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  return await getStaticPathsBlogCategory({ paginate });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths> & {
  category: Record<string, string>;
  seriesList: Array<{ slug: string; title: string }>;
};

const { page, category, seriesList = [] } = Astro.props as Props;

const currentPage = page.currentPage ?? 1;

const thirtyDaysAgo = new Date();
thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);

const categoryDescriptions: Record<string, string> = {
  'quick-take': 'Short, punchy perspectives on bioinformatics news and ideas.',
  'deep-dive': 'In-depth explorations of complex topics in computational biology.',
  tutorial: 'Step-by-step guides to build your bioinformatics skills.',
  interview: 'Conversations with leaders and innovators in the field.',
};

const categoryDescription = categoryDescriptions[category.slug] ?? '';

// Build a set of tag slugs that appear on more than one post in this page
const tagCounts = new Map<string, number>();
page.data.forEach((post) => {
  if ('tags' in post && Array.isArray(post.tags)) {
    post.tags.forEach((t) => tagCounts.set(t.slug, (tagCounts.get(t.slug) ?? 0) + 1));
  }
});
const sharedTagSlugs = new Set([...tagCounts.entries()].filter(([, count]) => count > 1).map(([slug]) => slug));

// Hide series buttons only when every visible post belongs to the exact same single series
const visiblePostSeriesSlugs = new Set(
  page.data.flatMap((post) => ('series' in post && post.series?.slug ? [post.series.slug] : []))
);
const visibleSeriesList = visiblePostSeriesSlugs.size === 1 ? [] : seriesList;

const metadata = {
  title: `Category '${category.title}' ${currentPage > 1 ? ` — Page ${currentPage}` : ''}`,
  robots: {
    index: blogCategoryRobots?.index,
    follow: blogCategoryRobots?.follow,
  },
};
---

<Layout metadata={metadata}>
  <section class="px-4 sm:px-6 lg:px-8 pt-3 pb-12 mx-auto max-w-6xl">
    <div class="mb-2">
      <a
        href="/blog"
        class="inline-flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-primary dark:hover:text-primary transition-colors duration-200"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
        </svg>
        All Categories
      </a>
    </div>

    <Headline title={category.title} classes={{ container: 'my-2 md:my-3' }} />

    {
      categoryDescription && (
        <p class="text-center text-gray-500 dark:text-gray-400 text-base max-w-xl mx-auto -mt-2 mb-2">
          {categoryDescription}
        </p>
      )
    }

    <!-- Search + Sort controls -->
    <div class="flex flex-col sm:flex-row gap-3 mt-6 mb-6">
      <!-- Search bar -->
      <div class="relative flex-1">
        <svg
          class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 dark:text-gray-500 pointer-events-none"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"></path>
        </svg>
        <input
          id="search-input"
          type="search"
          placeholder="Search posts…"
          class="w-full pl-12 pr-4 py-4 text-base rounded-xl border-2 border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 text-gray-900 dark:text-slate-100 placeholder-gray-400 dark:placeholder-gray-500 focus:ring-2 focus:ring-primary focus:border-primary transition-colors duration-200 shadow-sm"
          autocomplete="off"
        />
      </div>

      <!-- Sort button -->
      <button
        id="sort-btn"
        data-order="desc"
        class="inline-flex items-center gap-2 px-6 py-4 rounded-xl border-2 border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 text-gray-700 dark:text-slate-300 font-medium text-base hover:border-primary hover:text-primary dark:hover:border-primary dark:hover:text-primary transition-colors duration-200 shadow-sm whitespace-nowrap"
      >
        <svg
          id="sort-icon"
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9M3 12h5m10 0l-4 4m4-4l-4-4"></path>
        </svg>
        <span id="sort-label">Newest first</span>
      </button>
    </div>

    {
      visibleSeriesList.length > 0 && (
        <div class="flex flex-wrap gap-2 items-center mb-6">
          <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Browse by series:</span>
          {visibleSeriesList.map((s) => (
            <a
              href={getPermalink(s.slug, 'series')}
              class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-medium bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300 hover:bg-purple-200 dark:hover:bg-purple-900/60 transition-colors duration-150"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0l-4-4m4 4l-4 4" />
              </svg>
              {s.title}
            </a>
          ))}
        </div>
      )
    }

    <p id="results-count" aria-live="polite" class="text-sm text-muted dark:text-slate-400 mb-6 hidden">
      Showing <span id="results-visible"></span> of {page.data.length} posts
    </p>

    <!-- Posts list -->
    <ul id="posts-list">
      {
        page.data.map((post) => {
          const authorNames = post.authors ? post.authors.map((a) => a.name).join(' ') : '';
          const tagTitles = 'tags' in post && post.tags ? post.tags.map((t) => t.title).join(' ') : '';
          const seriesTitle = 'series' in post && post.series ? (post.series as { title: string }).title : '';
          const searchData = [post.title, authorNames, tagTitles, seriesTitle].join(' ').toLowerCase();
          const dateMs = new Date(post.publishDate).getTime();
          const isNew = new Date(post.publishDate) >= thirtyDaysAgo;

          return (
            <li class="mb-8 md:mb-12" data-search={searchData} data-date={dateMs}>
              <PostListItem post={post} sharedTagSlugs={sharedTagSlugs} isNew={isNew} />
            </li>
          );
        })
      }
    </ul>

    <p id="no-results" class="hidden text-center text-gray-500 dark:text-gray-400 py-12 text-lg">
      No posts match your search.
    </p>

    <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
  </section>
</Layout>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const sortBtn = document.getElementById('sort-btn') as HTMLButtonElement;
  const sortLabel = document.getElementById('sort-label') as HTMLSpanElement;
  const sortIcon = document.getElementById('sort-icon') as unknown as SVGElement;
  const postsList = document.getElementById('posts-list') as HTMLUListElement;
  const resultsCount = document.getElementById('results-count') as HTMLParagraphElement;
  const resultsVisible = document.getElementById('results-visible') as HTMLSpanElement;
  const noResults = document.getElementById('no-results') as HTMLParagraphElement;

  // Icons for the two sort directions
  const iconDesc = `<path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9M3 12h5m10 0l-4 4m4-4l-4-4" />`;
  const iconAsc = `<path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9M3 12h5m10 8l-4-4m4 4l-4-4" />`;

  function getItems() {
    return Array.from(postsList.querySelectorAll<HTMLLIElement>('li[data-search]'));
  }

  function applyFilter(items: HTMLLIElement[]) {
    const query = searchInput.value.trim().toLowerCase();
    let visibleCount = 0;

    items.forEach((li) => {
      const matches = !query || (li.getAttribute('data-search') || '').includes(query);
      li.style.display = matches ? '' : 'none';
      if (matches) visibleCount++;
    });

    noResults.classList.toggle('hidden', visibleCount > 0);

    if (query) {
      resultsCount.classList.remove('hidden');
      resultsVisible.textContent = String(visibleCount);
    } else {
      resultsCount.classList.add('hidden');
    }
  }

  function applySort(order: 'asc' | 'desc') {
    const items = getItems();
    items.sort((a, b) => {
      const da = Number(a.getAttribute('data-date'));
      const db = Number(b.getAttribute('data-date'));
      return order === 'desc' ? db - da : da - db;
    });
    items.forEach((li) => postsList.appendChild(li));
  }

  function update() {
    applyFilter(getItems());
  }

  sortBtn.addEventListener('click', () => {
    const current = sortBtn.getAttribute('data-order') as 'asc' | 'desc';
    const next = current === 'desc' ? 'asc' : 'desc';
    sortBtn.setAttribute('data-order', next);
    sortLabel.textContent = next === 'desc' ? 'Newest first' : 'Oldest first';
    sortIcon.innerHTML = next === 'desc' ? iconDesc : iconAsc;
    applySort(next);
    update();
  });

  searchInput.addEventListener('input', update);

  // Restore search query from URL
  const params = new URLSearchParams(window.location.search);
  const q = params.get('q');
  if (q) {
    searchInput.value = q;
    update();
  }
</script>
