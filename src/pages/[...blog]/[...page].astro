---
import type { GetStaticPaths } from 'astro';

import Layout from '~/layouts/PageLayout.astro';
import PostListItem from '~/components/ui/PostListItem.astro';
import Headline from '~/components/ui/Headline.astro';

import { blogListRobots, getStaticPathsBlogListAll } from '~/utils/blog';
import { getPermalink } from '~/utils/permalinks';
import type { Post } from '~/types';

export const prerender = true;

export const getStaticPaths = (async () => {
  return await getStaticPathsBlogListAll();
}) satisfies GetStaticPaths;

const { posts } = Astro.props as { posts: Post[] };

const categories = [
  { label: 'Quick Takes', href: getPermalink('quick-take', 'category'), comingSoon: false },
  { label: 'Deep Dives', href: getPermalink('deep-dive', 'category'), comingSoon: false },
  { label: 'Tutorials', href: getPermalink('tutorial', 'category'), comingSoon: false },
  { label: 'Interviews', href: '#', comingSoon: true },
];

const metadata = {
  title: 'Blog',
  robots: {
    index: blogListRobots?.index,
    follow: blogListRobots?.follow,
  },
  openGraph: {
    type: 'blog',
  },
};
---

<Layout metadata={metadata}>
  <section class="px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <Headline
      title="The Blog"
      subtitle="Enjoy news, tutorials, resources and other interesting content related to bioinformatics"
    />

    <!-- Category Buttons -->
    <div class="flex flex-wrap gap-3 justify-center mb-10">
      {
        categories.map((cat) =>
          cat.comingSoon ? (
            <span class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-medium border-2 border-gray-300 dark:border-gray-600 text-gray-400 dark:text-gray-500 cursor-not-allowed">
              {cat.label}
              <span class="text-xs font-semibold uppercase tracking-wide bg-gray-200 dark:bg-gray-700 text-gray-500 dark:text-gray-400 px-2 py-0.5 rounded-full">
                Coming Soon
              </span>
            </span>
          ) : (
            <a
              href={cat.href}
              class="inline-flex items-center px-6 py-3 rounded-full text-sm font-medium border-2 border-primary text-primary hover:bg-primary hover:text-white transition-colors duration-200"
            >
              {cat.label}
            </a>
          )
        )
      }
    </div>

    <!-- Search Bar -->
    <div class="relative mb-10">
      <svg
        class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 dark:text-gray-500 pointer-events-none"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"
        ></path>
      </svg>
      <input
        id="search-input"
        type="search"
        placeholder="Search by title, author, tag, or series…"
        class="w-full pl-12 pr-4 py-3 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 text-gray-900 dark:text-slate-100 placeholder-gray-400 dark:placeholder-gray-500 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors duration-200"
        autocomplete="off"
      />
    </div>

    <p id="results-count" aria-live="polite" class="text-sm text-muted dark:text-slate-400 mb-6 hidden">
      Showing <span id="results-visible"></span> of {posts.length} posts
    </p>

    <!-- Posts List -->
    <ul id="posts-list">
      {
        posts.map((post) => {
          const authorNames = post.authors ? post.authors.map((a) => a.name).join(' ') : '';
          const seriesTitle = post.series?.title || '';
          const tagTitles = post.tags ? post.tags.map((t) => t.title).join(' ') : '';
          const searchData = [post.title, authorNames, seriesTitle, tagTitles].join(' ').toLowerCase();

          return (
            <li class="mb-12 md:mb-20" data-search={searchData}>
              <PostListItem post={post} />
            </li>
          );
        })
      }
    </ul>

    <p id="no-results" class="hidden text-center text-gray-500 dark:text-gray-400 py-12 text-lg">
      No posts match your search.
    </p>
  </section>
</Layout>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const postsList = document.getElementById('posts-list');
  const resultsCount = document.getElementById('results-count');
  const resultsVisible = document.getElementById('results-visible');
  const noResults = document.getElementById('no-results');

  if (searchInput && postsList && resultsCount && resultsVisible && noResults) {
    function applySearch() {
      const query = searchInput.value.trim().toLowerCase();
      const items = postsList!.querySelectorAll('li[data-search]');
      let visibleCount = 0;

      items.forEach((li) => {
        const searchData = li.getAttribute('data-search') || '';
        const matches = !query || searchData.includes(query);

        (li as HTMLElement).style.display = matches ? '' : 'none';
        if (matches) visibleCount++;
      });

      noResults!.classList.toggle('hidden', visibleCount > 0);

      if (query) {
        resultsCount!.classList.remove('hidden');
        resultsVisible!.textContent = String(visibleCount);
      } else {
        resultsCount!.classList.add('hidden');
      }

      const params = new URLSearchParams();
      if (query) params.set('q', query);
      const newUrl = params.toString() ? `${window.location.pathname}?${params.toString()}` : window.location.pathname;
      window.history.replaceState({}, '', newUrl);
    }

    function initFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const q = params.get('q');
      if (q) {
        searchInput.value = q;
        applySearch();
      }
    }

    searchInput.addEventListener('input', applySearch);
    initFromUrl();
  }
</script>
